{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "build": {
        "dockerfile": "backend/Dockerfile"
      },
      "port": 3000,
      "volumes": [
        {
          "name": "backend-uploads",
          "mountPath": "/app/uploads"
        },
        {
          "name": "backend-logs",
          "mountPath": "/app/logs"
        }
      ]
    }
  }
}
